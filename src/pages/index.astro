---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Background Effects -->
  <div class="fixed inset-0 pointer-events-none z-0">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-accent/5 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-accent/3 rounded-full blur-[120px]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
  </div>

  <main class="relative z-10">
    <!-- Hero -->
    <section class="min-h-screen flex flex-col items-center justify-center px-6 py-20 text-center">
      <div class="max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm text-text-secondary mb-8 animate-fade-in">
          <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
          Free & Open Source
        </div>
        
        <h1 class="font-[family-name:var(--font-display)] text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.1] tracking-tight mb-6">
          <span class="text-gradient">Your network</span>
          <br />
          <span class="text-text">speed, always</span>
          <br />
          <span class="text-gradient">visible</span>
        </h1>
        
        <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-12 leading-relaxed">
          Real-time upload and download speeds in your macOS menu bar.
          <br class="hidden md:block" />
          No apps to open. No dashboards to check.
        </p>
        
        <!-- Floating Menu Bar Mockup -->
        <div class="relative mx-auto mb-12 animate-float">
          <div class="absolute -inset-4 bg-accent/20 rounded-2xl blur-2xl"></div>
          <div class="relative glass rounded-xl px-8 py-4 inline-flex items-center gap-6 shadow-2xl">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-text-muted" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
              </svg>
              <span class="text-text-muted text-sm">9:41</span>
            </div>
            <div class="w-px h-6 bg-border"></div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-text-muted" viewBox="0 0 16 12" fill="currentColor">
                <path d="M8 0C5.1 0 2.4 1.2 0.4 3.2L8 11.5L15.6 3.2C13.6 1.2 10.9 0 8 0ZM8 9.5L2.5 4C4.1 2.6 6 1.8 8 1.8C10 1.8 11.9 2.6 13.5 4L8 9.5Z"/>
              </svg>
            </div>
            <div class="w-px h-6 bg-border"></div>
            <div class="font-[family-name:var(--font-mono)] text-sm flex items-center gap-4">
              <span class="flex items-center gap-1.5">
                <span class="text-accent text-xs">↓</span>
                <span class="animate-number-change-down text-text">24.1</span>
                <span class="text-text-muted text-xs">MB/s</span>
              </span>
              <span class="flex items-center gap-1.5">
                <span class="text-success text-xs">↑</span>
                <span class="animate-number-change-up text-text">4.8</span>
                <span class="text-text-muted text-xs">MB/s</span>
              </span>
            </div>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="https://github.com/charandeep-reddy/traffy/releases/latest"
            class="group inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent text-bg font-semibold rounded-full hover:bg-accent/90 transition-all duration-300 hover:scale-105 glow-accent"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Download for macOS
          </a>
          <a 
            href="https://github.com/charandeep-reddy/traffy"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 glass text-text font-medium rounded-full hover:bg-white/5 transition-all duration-300"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- The Lie -->
    <section class="min-h-screen flex items-center px-6 py-20">
      <div class="max-w-5xl mx-auto w-full">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            <div class="inline-flex items-center gap-2 text-danger text-sm font-medium">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              The Problem
            </div>
            <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-bold leading-tight">
              Full bars.
              <br />
              <span class="text-text-secondary">Zero truth.</span>
            </h2>
            <p class="text-lg text-text-secondary leading-relaxed">
              Your menu bar shows full signal strength. Strong Wi-Fi. But full bars only mean radio waves are reaching your router. They say nothing about whether data is actually moving, or how fast.
            </p>
          </div>
          
          <div class="relative">
            <div class="absolute -inset-8 bg-danger/5 rounded-full blur-3xl"></div>
            <div class="relative glass rounded-2xl p-8 space-y-6">
              <div class="flex items-center justify-between">
                <span class="text-text-secondary text-sm">Signal Strength</span>
                <div class="flex items-end gap-1">
                  <div class="w-2 h-3 bg-success rounded-sm"></div>
                  <div class="w-2 h-5 bg-success rounded-sm"></div>
                  <div class="w-2 h-7 bg-success rounded-sm"></div>
                  <div class="w-2 h-9 bg-success rounded-sm"></div>
                </div>
              </div>
              <div class="h-px bg-border"></div>
              <div class="flex items-center justify-between">
                <span class="text-text-secondary text-sm">Actual Speed</span>
                <span class="font-[family-name:var(--font-mono)] text-danger text-lg">0.0 KB/s</span>
              </div>
              <div class="h-px bg-border"></div>
              <div class="text-center py-2">
                <span class="text-danger/80 text-sm">Connected doesn't mean working.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Question -->
    <section class="min-h-[70vh] flex items-center justify-center px-6 py-20 text-center">
      <div class="max-w-3xl mx-auto space-y-8">
        <p class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-medium leading-tight text-text">
          What if your menu bar showed you the actual truth?
        </p>
        <p class="text-xl md:text-2xl text-text-secondary">
          Not signal. Not bars. <span class="text-accent">Just numbers.</span>
        </p>
      </div>
    </section>

    <!-- The Fix -->
    <section class="min-h-screen flex items-center justify-center px-6 py-20 text-center">
      <div class="max-w-4xl mx-auto space-y-12">
        <h2 class="font-[family-name:var(--font-display)] text-6xl md:text-8xl font-bold text-gradient">
          Traffy
        </h2>
        
        <div class="relative mx-auto">
          <div class="absolute -inset-8 bg-accent/10 rounded-3xl blur-3xl animate-pulse"></div>
          <div class="relative glass rounded-2xl p-6 md:p-8 inline-block shadow-2xl border border-accent/20">
            <div class="flex items-center gap-6 md:gap-8">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-text-muted" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                </svg>
                <span class="text-text-muted text-sm font-medium">9:41</span>
              </div>
              <div class="w-px h-6 bg-border"></div>
              <div class="font-[family-name:var(--font-mono)] text-base md:text-lg flex items-center gap-6">
                <span class="flex items-center gap-2">
                  <span class="text-accent">↓</span>
                  <span class="animate-number-change-down text-text tabular-nums">24.1</span>
                  <span class="text-text-muted text-xs">MB/s</span>
                </span>
                <span class="flex items-center gap-2">
                  <span class="text-success">↑</span>
                  <span class="animate-number-change-up text-text tabular-nums">4.8</span>
                  <span class="text-text-muted text-xs">MB/s</span>
                </span>
              </div>
            </div>
          </div>
        </div>
        
        <p class="text-lg text-text-secondary max-w-xl mx-auto">
          Live upload and download speeds. Always visible. Always real.
        </p>
      </div>
    </section>

    <!-- Features -->
    <section class="px-6 py-20">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold mb-4">
            Everything you need.
            <span class="text-text-secondary">Nothing you don't.</span>
          </h2>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            { title: "Split or Combined", desc: "See both directions, or just the one that's active.", icon: "split" },
            { title: "Bytes or Bits", desc: "B/s, KB/s, MB/s or b/s, Kbps, Mbps. Your choice.", icon: "scale" },
            { title: "Your Interval", desc: "Refresh every 1, 2, or 3 seconds. However you like it.", icon: "clock" },
            { title: "Launch at Login", desc: "Starts when you start. Lives in the menu bar. Never in the dock.", icon: "power" },
            { title: "Zero Bloat", desc: "Pure Swift. Reads local system counters. No network calls. No telemetry.", icon: "shield" },
            { title: "Native Feel", desc: "macOS 13+. Apple Silicon or Intel. Feels like it belongs.", icon: "device" }
          ].map(feature => (
            <div class="group glass rounded-2xl p-8 hover:bg-white/5 transition-all duration-500 hover:-translate-y-1">
              <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
                {feature.icon === "split" && (
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                  </svg>
                )}
                {feature.icon === "scale" && (
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
                  </svg>
                )}
                {feature.icon === "clock" && (
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                )}
                {feature.icon === "power" && (
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                )}
                {feature.icon === "shield" && (
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                )}
                {feature.icon === "device" && (
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                )}
              </div>
              <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold mb-2">{feature.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The Why -->
    <section class="px-6 py-20">
      <div class="max-w-4xl mx-auto space-y-16">
        <div class="text-center">
          <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold mb-4">
            Why it matters
          </h2>
        </div>
        
        <div class="space-y-8">
          <div class="glass rounded-2xl p-8 md:p-10 border-l-4 border-danger/50">
            <p class="text-lg md:text-xl leading-relaxed mb-4">
              Your upload is stuck at <span class="font-[family-name:var(--font-mono)] text-danger">0 KB/s</span>.
            </p>
            <p class="text-text-secondary">
              Dropbox isn't syncing — or your VPN is choking. The bars say full. Traffy says the truth.
            </p>
          </div>
          
          <div class="glass rounded-2xl p-8 md:p-10 border-l-4 border-accent/50">
            <p class="text-lg md:text-xl leading-relaxed mb-4">
              You're on a call. The bars say full.
            </p>
            <p class="text-text-secondary">
              But your upload is <span class="font-[family-name:var(--font-mono)] text-accent">0.2 Mbps</span>. Now you know why it stutters.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="min-h-[80vh] flex items-center justify-center px-6 py-20 text-center">
      <div class="max-w-3xl mx-auto space-y-10">
        <div class="space-y-4">
          <p class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-medium leading-tight">
            Signal strength is one question.
          </p>
          <p class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold text-gradient">
            Speed is the answer.
          </p>
        </div>
        
        <p class="text-text-secondary text-lg">
          Traffy. Free. Open source. Made by <a href="https://psydevx.app" class="text-accent hover:underline">psydevx</a>.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
          <a 
            href="https://github.com/charandeep-reddy/traffy/releases/latest"
            class="group inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent text-bg font-semibold rounded-full hover:bg-accent/90 transition-all duration-300 hover:scale-105 glow-accent"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Download for macOS
          </a>
          <a 
            href="https://github.com/charandeep-reddy/traffy"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 glass text-text font-medium rounded-full hover:bg-white/5 transition-all duration-300"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-border py-8 px-6">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-text-muted">
        <div class="flex items-center gap-6">
          <a href="https://github.com/charandeep-reddy/traffy" class="hover:text-text transition-colors">GitHub</a>
          <a href="https://github.com/charandeep-reddy/traffy/blob/main/LICENSE" class="hover:text-text transition-colors">MIT License</a>
          <a href="https://psydevx.app" class="hover:text-text transition-colors">psydevx.app</a>
        </div>
        <p>© 2026 Traffy. Free forever.</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
  
  @keyframes number-change-down {
    0%, 100% { content: "24.1"; }
    10% { content: "18.7"; }
    20% { content: "31.2"; }
    30% { content: "15.4"; }
    40% { content: "42.8"; }
    50% { content: "28.6"; }
    60% { content: "12.3"; }
    70% { content: "35.9"; }
    80% { content: "19.5"; }
    90% { content: "27.1"; }
  }
  
  @keyframes number-change-up {
    0%, 100% { content: "4.8"; }
    15% { content: "2.1"; }
    30% { content: "6.3"; }
    45% { content: "1.7"; }
    60% { content: "5.9"; }
    75% { content: "3.4"; }
    90% { content: "7.2"; }
  }
  
  .animate-number-change-down::after {
    content: "24.1";
    animation: number-change-down 8s ease-in-out infinite;
  }
  
  .animate-number-change-up::after {
    content: "4.8";
    animation: number-change-up 8s ease-in-out infinite;
  }
  
  .animate-number-change-down,
  .animate-number-change-up {
    font-size: 0;
  }
  
  .animate-number-change-down::after,
  .animate-number-change-up::after {
    font-size: 1rem;
  }
</style>
