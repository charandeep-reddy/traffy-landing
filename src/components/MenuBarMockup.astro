---
interface Props {
  large?: boolean;
}

const { large } = Astro.props;
---

<div class:list={["mockup", large && "mockup-lg"]}>
  <div class="mockup-body">
    <span class="slot down">
      <span class="arr">↓</span>
      <span class="num" id="down-val">24.1</span>
      <span class="suf">MB/s</span>
    </span>
    <span class="slot up">
      <span class="arr">↑</span>
      <span class="num" id="up-val">4.8</span>
      <span class="suf">MB/s</span>
    </span>
  </div>
</div>

<script>
  const downEl = document.getElementById('down-val');
  const upEl = document.getElementById('up-val');

  function rand(min: number, max: number) {
    return (Math.random() * (max - min) + min).toFixed(1);
  }

  function tick() {
    downEl.textContent = rand(12, 45);
    upEl.textContent = rand(1.5, 8);
  }

  setInterval(tick, 1800);
  tick();
</script>

<style>
  .mockup {
    display: inline-flex;
    align-items: center;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 12px 22px;
  }

  .mockup-lg {
    padding: 16px 28px;
    border-radius: 20px;
    box-shadow: 0 0 60px rgba(0, 122, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .mockup-body {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .mockup-lg .mockup-body {
    gap: 26px;
  }

  .slot {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: 'JetBrains Mono', 'SF Mono', SFMono-Regular, ui-monospace, monospace;
  }

  .arr {
    font-size: 11px;
    opacity: 0.5;
  }

  .mockup-lg .arr {
    font-size: 13px;
  }

  .num {
    font-variant-numeric: tabular-nums;
    min-width: 42px;
    text-align: right;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
  }

  .mockup-lg .num {
    font-size: 18px;
    min-width: 50px;
  }

  .suf {
    font-size: 10px;
    opacity: 0.4;
    margin-left: 1px;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  }

  .mockup-lg .suf {
    font-size: 12px;
  }
</style>
