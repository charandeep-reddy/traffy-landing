---
interface Props {
  large?: boolean;
  class?: string;
}

const { large, class: className } = Astro.props;
---

<div class={`inline-flex items-center gap-3
    ${large
      ? 'bg-[rgba(44,44,46,0.9)] backdrop-blur-xl rounded-[10px] px-5 py-2.5 border border-[rgba(255,255,255,0.1)] text-base shadow-[0_0_0_1px_rgba(0,0,0,0.2),0_8px_40px_rgba(0,0,0,0.5),0_0_100px_rgba(0,122,255,0.12)]'
      : 'bg-[rgba(44,44,46,0.85)] backdrop-blur-xl rounded-lg px-4 py-[7px] border border-[rgba(255,255,255,0.08)] shadow-[0_0_0_1px_rgba(0,0,0,0.2),0_4px_24px_rgba(0,0,0,0.4),0_0_80px_rgba(0,122,255,0.1)] animate-float'
    }
    ${className || ''}`}>
  <!-- Left: Apple logo + time -->
  <div class="flex items-center gap-2.5">
    <span class="text-sm opacity-85">&#63743;</span>
    <span class="font-medium opacity-90 text-sm">9:41</span>
  </div>

  <!-- Separator -->
  <div class="w-px h-4 bg-white/15"></div>

  <!-- Right: Wi-Fi icon + speed -->
  <div class="flex items-center gap-3">
    <svg class="opacity-60" width="14" height="11" viewBox="0 0 16 12" fill="currentColor">
      <path d="M8 0C5.1 0 2.4 1.2 0.4 3.2L8 11.5L15.6 3.2C13.6 1.2 10.9 0 8 0ZM8 9.5L2.5 4C4.1 2.6 6 1.8 8 1.8C10 1.8 11.9 2.6 13.5 4L8 9.5Z"/>
    </svg>

    <div class={`flex items-center ${large ? 'gap-[18px]' : 'gap-[14px]'} font-mono text-xs font-medium`}>
      <span class="flex items-center gap-[3px]">
        <span class="text-accent text-[10px]">↓</span>
        <span class="tabular-nums min-w-[36px] text-right speed-anim-down">24.1</span>
        <span class="opacity-50 text-[10px] ml-[1px]">MB/s</span>
      </span>
      <span class="flex items-center gap-[3px]">
        <span class="text-success text-[10px]">↑</span>
        <span class="tabular-nums min-w-[36px] text-right speed-anim-up">4.8</span>
        <span class="opacity-50 text-[10px] ml-[1px]">MB/s</span>
      </span>
    </div>
  </div>
</div>
