---
// MenuBarSimulator.astro
---

<div
  class="relative z-40 inline-block text-left select-none"
  id="sim-container"
>
  <!-- Outer Menu Bar Pill -->
  <button
    id="sim-trigger"
    class="flex items-center gap-4 px-5 py-2.5 rounded-full border border-white/10 bg-bg-elevated/80 shadow-[0_4px_20px_rgba(0,122,255,0.06)] hover:border-white/20 hover:bg-bg-elevated hover:shadow-[0_8px_30px_rgba(0,122,255,0.12)] transition-all cursor-pointer group"
    aria-haspopup="true"
    aria-expanded="false"
  >
    <!-- Pulses green/blue to show live data -->
    <span class="relative flex h-2 w-2">
      <span
        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"
      ></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
    </span>

    <!-- Active Speed Display -->
    <span
      class="font-mono text-[13px] font-semibold text-text tracking-wide tabular-nums flex items-center gap-3.5 transition-colors"
      id="sim-display"
    >
      <!-- Loaded dynamically via script -->
      <span class="opacity-30">Initializing...</span>
    </span>

    <!-- Chevron to encourage clicking -->
    <svg
      class="w-3.5 h-3.5 text-text-secondary group-hover:text-text transition-colors"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.5"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
    </svg>
  </button>

  <!-- macOS Native Dropdown Menu -->
  <div
    id="sim-dropdown"
    class="absolute right-0 mt-2.5 w-[220px] rounded-xl border border-white/10 bg-[#0d0d16]/95 backdrop-blur-3xl shadow-[0_16px_50px_rgba(0,0,0,0.6)] p-1.5 z-50 origin-top-right scale-95 opacity-0 pointer-events-none transition-all duration-200"
    role="menu"
  >
    <div
      class="px-2.5 py-1 text-[11px] font-medium text-text-secondary tracking-wider uppercase opacity-40"
    >
      Traffy Menu
    </div>

    <!-- Real-time Speed Status -->
    <div
      class="px-2.5 py-2 mb-1 rounded-lg bg-white/3 border border-white/5 flex flex-col gap-0.5"
    >
      <div class="text-[10px] text-text-muted font-medium">REAL-TIME SPEED</div>
      <div
        class="font-mono text-xs font-semibold text-text flex items-center justify-between"
      >
        <span class="text-success flex items-center gap-1"
          >↓ <span id="dd-down">0.0</span></span
        >
        <span class="text-accent flex items-center gap-1"
          >↑ <span id="dd-up">0.0</span></span
        >
      </div>
    </div>

    <div class="h-[1px] bg-white/5 my-1"></div>

    <!-- Mode Submenu Item -->
    <div class="relative group/sub">
      <button
        class="w-full flex items-center justify-between px-2.5 py-1.5 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left transition-colors cursor-pointer"
      >
        <span>Mode</span>
        <span class="text-[10px] opacity-60 flex items-center gap-1">
          <span id="label-mode">Split</span>
          <span>&rsaquo;</span>
        </span>
      </button>

      <!-- Submenu -->
      <div
        class="absolute left-full top-0 ml-1.5 w-[130px] rounded-xl border border-white/10 bg-[#0d0d16]/95 backdrop-blur-2xl p-1 shadow-lg opacity-0 pointer-events-none group-hover/sub:opacity-100 group-hover/sub:pointer-events-auto transition-opacity duration-150 z-50"
      >
        <button
          class="w-full flex items-center justify-between px-2 py-1 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left cursor-pointer"
          id="btn-mode-split"
        >
          <span>Split</span>
          <span
            class="sub-check active text-accent group-hover:text-white font-bold"
            id="check-mode-split">✓</span
          >
        </button>
        <button
          class="w-full flex items-center justify-between px-2 py-1 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left cursor-pointer"
          id="btn-mode-combined"
        >
          <span>Combined</span>
          <span
            class="sub-check text-accent group-hover:text-white font-bold hidden"
            id="check-mode-combined">✓</span
          >
        </button>
      </div>
    </div>

    <!-- Unit Submenu Item -->
    <div class="relative group/sub">
      <button
        class="w-full flex items-center justify-between px-2.5 py-1.5 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left transition-colors cursor-pointer"
      >
        <span>Unit</span>
        <span class="text-[10px] opacity-60 flex items-center gap-1">
          <span id="label-unit">Bytes</span>
          <span>&rsaquo;</span>
        </span>
      </button>

      <!-- Submenu -->
      <div
        class="absolute left-full top-0 ml-1.5 w-[130px] rounded-xl border border-white/10 bg-[#0d0d16]/95 backdrop-blur-2xl p-1 shadow-lg opacity-0 pointer-events-none group-hover/sub:opacity-100 group-hover/sub:pointer-events-auto transition-opacity duration-150 z-50"
      >
        <button
          class="w-full flex items-center justify-between px-2 py-1 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left cursor-pointer"
          id="btn-unit-bytes"
        >
          <span>Bytes</span>
          <span
            class="sub-check active text-accent group-hover:text-white font-bold"
            id="check-unit-bytes">✓</span
          >
        </button>
        <button
          class="w-full flex items-center justify-between px-2 py-1 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left cursor-pointer"
          id="btn-unit-bits"
        >
          <span>Bits</span>
          <span
            class="sub-check text-accent group-hover:text-white font-bold hidden"
            id="check-unit-bits">✓</span
          >
        </button>
      </div>
    </div>

    <!-- Interval Submenu Item -->
    <div class="relative group/sub">
      <button
        class="w-full flex items-center justify-between px-2.5 py-1.5 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left transition-colors cursor-pointer"
      >
        <span>Interval</span>
        <span class="text-[10px] opacity-60 flex items-center gap-1">
          <span id="label-interval">1s</span>
          <span>&rsaquo;</span>
        </span>
      </button>

      <!-- Submenu -->
      <div
        class="absolute left-full top-0 ml-1.5 w-[100px] rounded-xl border border-white/10 bg-[#0d0d16]/95 backdrop-blur-2xl p-1 shadow-lg opacity-0 pointer-events-none group-hover/sub:opacity-100 group-hover/sub:pointer-events-auto transition-opacity duration-150 z-50"
      >
        <button
          class="w-full flex items-center justify-between px-2 py-1 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left cursor-pointer"
          id="btn-int-1s"
        >
          <span>1s</span>
          <span
            class="sub-check active text-accent group-hover:text-white font-bold"
            id="check-int-1s">✓</span
          >
        </button>
        <button
          class="w-full flex items-center justify-between px-2 py-1 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left cursor-pointer"
          id="btn-int-2s"
        >
          <span>2s</span>
          <span
            class="sub-check text-accent group-hover:text-white font-bold hidden"
            id="check-int-2s">✓</span
          >
        </button>
        <button
          class="w-full flex items-center justify-between px-2 py-1 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left cursor-pointer"
          id="btn-int-3s"
        >
          <span>3s</span>
          <span
            class="sub-check text-accent group-hover:text-white font-bold hidden"
            id="check-int-3s">✓</span
          >
        </button>
      </div>
    </div>

    <div class="h-[1px] bg-white/5 my-1"></div>

    <!-- Launch at Login Toggle -->
    <button
      class="w-full flex items-center justify-between px-2.5 py-1.5 text-xs text-text hover:bg-accent hover:text-white rounded-md text-left cursor-pointer transition-colors"
      id="btn-login"
    >
      <span>Launch at Login</span>
      <span class="font-bold text-accent" id="check-login">✓</span>
    </button>

    <div class="h-[1px] bg-white/5 my-1"></div>

    <!-- Quit Button -->
    <button
      class="w-full flex items-center justify-between px-2.5 py-1.5 text-xs text-[#ff453a] hover:bg-danger hover:text-white rounded-md text-left cursor-pointer transition-colors"
      id="btn-quit"
    >
      <span>Quit Traffy</span>
      <span class="text-[10px] opacity-60">⌘Q</span>
    </button>
  </div>
</div>

<script>
  // --- STATE ---
  let displayMode = "split"; // split, combined
  let unitMode = "bytes"; // bytes, bits
  let intervalSeconds = 1; // 1, 2, 3
  let launchAtLogin = true;
  let timerId = null;

  // Cached speed values
  let curDownRaw = 24.1; // MB/s basis
  let curUpRaw = 4.8; // MB/s basis

  // --- SELECTORS ---
  const container = document.getElementById("sim-container");
  const trigger = document.getElementById("sim-trigger");
  const dropdown = document.getElementById("sim-dropdown");
  const display = document.getElementById("sim-display");

  // Dropdown info speed counters
  const ddDown = document.getElementById("dd-down");
  const ddUp = document.getElementById("dd-up");

  // Labels & checkmarks
  const labelMode = document.getElementById("label-mode");
  const labelUnit = document.getElementById("label-unit");
  const labelInterval = document.getElementById("label-interval");

  const checkModeSplit = document.getElementById("check-mode-split");
  const checkModeCombined = document.getElementById("check-mode-combined");
  const checkUnitBytes = document.getElementById("check-unit-bytes");
  const checkUnitBits = document.getElementById("check-unit-bits");
  const checkInt1s = document.getElementById("check-int-1s");
  const checkInt2s = document.getElementById("check-int-2s");
  const checkInt3s = document.getElementById("check-int-3s");
  const checkLogin = document.getElementById("check-login");

  // Dropdown Buttons
  const btnModeSplit = document.getElementById("btn-mode-split");
  const btnModeCombined = document.getElementById("btn-mode-combined");
  const btnUnitBytes = document.getElementById("btn-unit-bytes");
  const btnUnitBits = document.getElementById("btn-unit-bits");
  const btnInt1s = document.getElementById("btn-int-1s");
  const btnInt2s = document.getElementById("btn-int-2s");
  const btnInt3s = document.getElementById("btn-int-3s");
  const btnLogin = document.getElementById("btn-login");
  const btnQuit = document.getElementById("btn-quit");

  // --- UTILS & SPEED GENERATION ---
  function rand(min, max) {
    return Math.random() * (max - min) + min;
  }

  function formatSpeed(value, unit) {
    if (unit === "bytes") {
      if (value < 1) {
        return `${(value * 1024).toFixed(0)} KB/s`;
      }
      return `${value.toFixed(1)} MB/s`;
    } else {
      // Bits mode (multiply bytes by 8)
      const bitsVal = value * 8;
      if (bitsVal < 1) {
        return `${(bitsVal * 1024).toFixed(0)} Kbps`;
      }
      return `${bitsVal.toFixed(1)} Mbps`;
    }
  }

  // --- UPDATERS ---
  function updateUI() {
    // Generate new random speeds
    if (Math.random() > 0.85) {
      curDownRaw = rand(45, 98);
      curUpRaw = rand(10, 18);
    } else if (Math.random() > 0.5) {
      curDownRaw = rand(10, 32);
      curUpRaw = rand(1.5, 6.5);
    } else {
      curDownRaw = rand(0.1, 4.5);
      curUpRaw = rand(0.05, 0.9);
    }

    // Update Status panel counters in dropdown (always Split, raw format)
    if (ddDown && ddUp) {
      ddDown.textContent = formatSpeed(curDownRaw, unitMode);
      ddUp.textContent = formatSpeed(curUpRaw, unitMode);
    }

    // Render Menu Bar Display based on mode & unit
    let displayStr = "";
    const downFormatted = formatSpeed(curDownRaw, unitMode);
    const upFormatted = formatSpeed(curUpRaw, unitMode);

    if (displayMode === "split") {
      displayStr = `
        <span class="flex items-center gap-1 text-[#32d74b]">↓ <span class="text-text">${downFormatted.replace("/s", "").replace("bps", "")}</span></span>
        <span class="flex items-center gap-1 text-[#007aff]">↑ <span class="text-text">${upFormatted.replace("/s", "").replace("bps", "")}</span></span>
        <span class="text-[10px] text-text-muted uppercase ml-0.5">${unitMode === "bytes" ? "B" : "b"}</span>
      `;
    } else {
      // Combined: show whichever is greater
      if (curUpRaw >= curDownRaw) {
        displayStr = `
          <span class="flex items-center gap-1 text-[#007aff]">↑ <span class="text-text">${upFormatted.replace("/s", "").replace("bps", "")}</span></span>
          <span class="text-[10px] text-text-muted uppercase ml-0.5">${unitMode === "bytes" ? "B" : "b"}</span>
        `;
      } else {
        displayStr = `
          <span class="flex items-center gap-1 text-[#32d74b]">↓ <span class="text-text">${downFormatted.replace("/s", "").replace("bps", "")}</span></span>
          <span class="text-[10px] text-text-muted uppercase ml-0.5">${unitMode === "bytes" ? "B" : "b"}</span>
        `;
      }
    }

    if (display) {
      display.innerHTML = displayStr;
    }
  }

  // --- SCHEDULER ---
  function setupInterval() {
    if (timerId) clearInterval(timerId);
    updateUI(); // Run immediately
    timerId = setInterval(updateUI, intervalSeconds * 1000);
  }

  // --- INTERACTION HANDLERS ---

  // Toggle Dropdown
  if (trigger) {
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.contains("opacity-100");
      if (isOpen) {
        closeDropdown();
      } else {
        openDropdown();
      }
    });
  }

  function openDropdown() {
    if (dropdown && trigger) {
      dropdown.classList.remove("opacity-0", "scale-95", "pointer-events-none");
      dropdown.classList.add("opacity-100", "scale-100", "pointer-events-auto");
      trigger.setAttribute("aria-expanded", "true");
    }
  }

  function closeDropdown() {
    if (dropdown && trigger) {
      dropdown.classList.remove(
        "opacity-100",
        "scale-100",
        "pointer-events-auto",
      );
      dropdown.classList.add("opacity-0", "scale-95", "pointer-events-none");
      trigger.setAttribute("aria-expanded", "false");
    }
  }

  // Close when clicking outside
  document.addEventListener("click", () => closeDropdown());
  if (dropdown) {
    dropdown.addEventListener("click", (e) => e.stopPropagation());
  }

  // --- DROPDOWN CONTROL HANDLERS ---

  // Mode Split
  if (btnModeSplit) {
    btnModeSplit.addEventListener("click", () => {
      displayMode = "split";
      labelMode.textContent = "Split";
      checkModeSplit.classList.remove("hidden");
      checkModeCombined.classList.add("hidden");
      updateUI();
    });
  }

  // Mode Combined
  if (btnModeCombined) {
    btnModeCombined.addEventListener("click", () => {
      displayMode = "combined";
      labelMode.textContent = "Combined";
      checkModeSplit.classList.add("hidden");
      checkModeCombined.classList.remove("hidden");
      updateUI();
    });
  }

  // Unit Bytes
  if (btnUnitBytes) {
    btnUnitBytes.addEventListener("click", () => {
      unitMode = "bytes";
      labelUnit.textContent = "Bytes";
      checkUnitBytes.classList.remove("hidden");
      checkUnitBits.classList.add("hidden");
      updateUI();
    });
  }

  // Unit Bits
  if (btnUnitBits) {
    btnUnitBits.addEventListener("click", () => {
      unitMode = "bits";
      labelUnit.textContent = "Bits";
      checkUnitBytes.classList.add("hidden");
      checkUnitBits.classList.remove("hidden");
      updateUI();
    });
  }

  // Intervals
  if (btnInt1s) {
    btnInt1s.addEventListener("click", () => {
      intervalSeconds = 1;
      labelInterval.textContent = "1s";
      checkInt1s.classList.remove("hidden");
      checkInt2s.classList.add("hidden");
      checkInt3s.classList.add("hidden");
      setupInterval();
    });
  }

  if (btnInt2s) {
    btnInt2s.addEventListener("click", () => {
      intervalSeconds = 2;
      labelInterval.textContent = "2s";
      checkInt1s.classList.add("hidden");
      checkInt2s.classList.remove("hidden");
      checkInt3s.classList.add("hidden");
      setupInterval();
    });
  }

  if (btnInt3s) {
    btnInt3s.addEventListener("click", () => {
      intervalSeconds = 3;
      labelInterval.textContent = "3s";
      checkInt1s.classList.add("hidden");
      checkInt2s.classList.add("hidden");
      checkInt3s.classList.remove("hidden");
      setupInterval();
    });
  }

  // Login Toggle
  if (btnLogin) {
    btnLogin.addEventListener("click", () => {
      launchAtLogin = !launchAtLogin;
      if (launchAtLogin) {
        checkLogin.classList.remove("hidden");
      } else {
        checkLogin.classList.add("hidden");
      }
    });
  }

  // Quit action simulator
  if (btnQuit) {
    btnQuit.addEventListener("click", () => {
      if (display) {
        display.innerHTML =
          '<span class="opacity-40">Offline (Traffy Quit)</span>';
      }
      clearInterval(timerId);
      closeDropdown();
      setTimeout(() => {
        setupInterval();
      }, 4000);
    });
  }

  // --- INITIALIZE ---
  setupInterval();
</script>
