---
import { DOWNLOAD_URL, REPO_URL } from '../constants';
---

<section class="py-32 px-6 text-center relative overflow-hidden">
  
  <!-- Glowing Background Spotlight -->
  <div class="absolute bottom-[-150px] left-1/2 -translate-x-1/2 w-[70vw] max-w-[800px] h-[50vh] pointer-events-none"
       style="background: radial-gradient(ellipse at center, rgba(88,86,214,0.11) 0%, transparent 60%);">
  </div>
  
  <div class="reveal relative z-10 max-w-[700px] mx-auto">
    <h2 class="font-display text-[clamp(36px,4.5vw,60px)] font-bold tracking-[-0.04em] leading-[1.08] mb-6">
      Signal strength is a promise.<br>
      <span class="text-gradient">Traffy is the reality.</span>
    </h2>
    
    <p class="text-text-secondary text-sm sm:text-[16px] leading-relaxed mb-10 max-w-[460px] mx-auto">
      Free. Open source. Featherweight. Get real upload and download metrics instantly in your menu bar today.
    </p>
    
    <!-- Actions -->
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={DOWNLOAD_URL}
         class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent text-white rounded-full font-semibold text-xs no-underline
                transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_8px_30px_rgba(88,86,214,0.35)] hover:bg-accent/90 shadow-[0_4px_16px_rgba(88,86,214,0.2)]">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download for macOS
      </a>
      <a href={REPO_URL}
         class="inline-flex items-center gap-2 px-8 py-3.5 bg-bg-card text-text rounded-full font-semibold text-xs no-underline
                border border-white/5 transition-all duration-300 hover:bg-white/5 hover:border-white/10 shadow-[0_4px_16px_rgba(0,0,0,0.2)]">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View Code
      </a>
    </div>
  </div>
</section>
