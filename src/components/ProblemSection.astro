            <div class="w-1.5 h-5 bg-success rounded-sm"></div>
            <div class="w-1.5 h-7 bg-success rounded-sm"></div>
          </div>
        </div>
        <div class="flex items-center justify-between py-4 border-t border-border">
          <span class="text-text-secondary text-sm">Actual Speed</span>
          <span class="font-mono text-[20px] font-semibold text-danger">0.0 KB/s</span>
        </div>
        <div class="text-center pt-4 border-t border-border">
          <span class="text-text-muted text-xs">Connected doesn't mean working.</span>
