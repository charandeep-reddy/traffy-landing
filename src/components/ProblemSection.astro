<section class="max-w-[1020px] mx-auto px-6 py-24 sm:py-32" id="problem">
  <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
    <div class="lg:col-span-5 reveal">
      <div class="inline-flex items-center gap-1.5 text-danger text-xs font-bold uppercase tracking-wider mb-4 select-none">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        The Problem
      </div>
      <h2 class="font-display text-[clamp(28px,4vw,44px)] font-bold leading-[1.1] tracking-tight mb-5">
        Full bars.<br>
        <span class="text-text-secondary font-serif italic">Zero truth.</span>
      </h2>
      <p class="text-text-secondary text-[15px] sm:text-[16px] leading-relaxed max-w-[460px]">
        Your macOS menu bar shows full signal strength. But Wi-Fi bars only tell you radio waves are reaching your router. They say nothing about whether data is actually moving, or how fast.
      </p>
    </div>

    <!-- Sharp Side-by-Side Technical Cards -->
    <div class="lg:col-span-7 reveal reveal-delay-1">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Card 1: Signal Strength -->
        <div class="bg-bg-card border border-border rounded-xl p-5 shadow-sm flex flex-col justify-between min-h-[160px]">
          <div>
            <div class="flex items-center justify-between mb-3">
              <span class="text-text-muted text-[10px] uppercase tracking-wider font-bold">Signal Status</span>
              <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-success/10 text-success text-[9px] font-bold">
                <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse-dot"></span>
                Connected
              </span>
            </div>
            <div class="flex items-end gap-1.5 my-3 h-10">
              <div class="w-2.5 h-3 bg-success rounded-xs"></div>
              <div class="w-2.5 h-5 bg-success rounded-xs"></div>
              <div class="w-2.5 h-7 bg-success rounded-xs"></div>
              <div class="w-2.5 h-9 bg-success rounded-xs"></div>
            </div>
          </div>
          <div class="border-t border-border/60 pt-3">
            <h4 class="text-xs font-bold text-text mb-0.5">Full Wi-Fi Signal</h4>
            <p class="text-[11px] text-text-secondary">Radio waves are successfully reaching your local router.</p>
          </div>
        </div>

        <!-- Card 2: Actual Speed -->
        <div class="bg-bg-card border border-border rounded-xl p-5 shadow-sm flex flex-col justify-between min-h-[160px]">
          <div>
            <div class="flex items-center justify-between mb-3">
              <span class="text-text-muted text-[10px] uppercase tracking-wider font-bold">Internet Throughput</span>
              <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-danger/10 text-danger text-[9px] font-bold">
                <span class="w-1.5 h-1.5 rounded-full bg-danger"></span>
                No Traffic
              </span>
            </div>
            <div class="my-3 flex items-baseline">
              <span class="font-mono text-2xl sm:text-3xl font-black text-danger tracking-tight">0.0</span>
              <span class="font-mono text-xs text-text-muted ml-1.5">KB/s</span>
            </div>
          </div>
          <div class="border-t border-border/60 pt-3">
            <h4 class="text-xs font-bold text-text mb-0.5">Zero Data Packets</h4>
            <p class="text-[11px] text-text-secondary">No actual internet connection is delivering packets.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
