<section class="max-w-[1100px] mx-auto px-6 py-20" id="problem">
  <div class="grid md:grid-cols-2 gap-[60px] items-center">
    <div class="reveal">
      <div class="inline-flex items-center gap-1.5 text-danger text-xs font-semibold uppercase tracking-wider mb-4">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        The Problem
      </div>
      <h2 class="font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] tracking-[-0.03em] mb-5">
        Full bars.<br>
        <span class="text-text-secondary">Zero truth.</span>
      </h2>
      <p class="text-text-secondary text-[17px] leading-relaxed max-w-[440px]">
