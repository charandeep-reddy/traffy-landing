---
// ProblemSection.astro
---

<section class="max-w-[1000px] mx-auto px-6 py-24 sm:py-32" id="problem">
  
  <!-- Header -->
  <div class="text-center mb-16 sm:mb-20 reveal">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-danger/10 border border-danger/15 text-danger text-[10px] font-bold uppercase tracking-wider mb-5">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      The Problem
    </div>
    <h2 class="font-display text-[clamp(28px,3.8vw,48px)] font-bold tracking-[-0.03em] mb-4">
      Full bars. Zero truth.
    </h2>
    <p class="text-text-secondary text-[15px] sm:text-base max-w-[500px] mx-auto">
      Your menu bar shows perfect signal waves. But traditional Wi-Fi status indicators say absolutely nothing about actual data movement.
    </p>
  </div>

  <!-- Comparison Grid -->
  <div class="grid md:grid-cols-2 gap-6 lg:gap-8 items-stretch">
    
    <!-- CARD 1: THE ILLUSION -->
    <div class="bg-bg-elevated border border-white/5 rounded-3xl p-7 sm:p-9 flex flex-col justify-between shadow-[0_12px_40px_rgba(0,0,0,0.4)] relative overflow-hidden group reveal">
      <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
      
      <div>
        <div class="text-[10px] font-mono text-text-muted uppercase tracking-widest mb-3">THE ILLUSION</div>
        <h3 class="text-xl font-bold mb-3">Wi-Fi Signal Bars</h3>
        <p class="text-text-secondary text-sm leading-relaxed mb-8">
          Displays five full status bars. Represents nothing more than radio frequency connection to your nearby access point. It is completely blind to network gateway drops, routing loops, or stalled DNS queries.
        </p>
      </div>

      <!-- Signal Bars Visual -->
      <div class="p-5 rounded-2xl bg-white/2 border border-white/5 flex items-center justify-between mt-4">
        <span class="text-xs text-text-secondary font-semibold">Signal Strength</span>
        <div class="flex items-end gap-[3.5px]">
          <div class="w-1.5 h-2 bg-success rounded-sm opacity-90"></div>
          <div class="w-1.5 h-4 bg-success rounded-sm opacity-90"></div>
          <div class="w-1.5 h-6 bg-success rounded-sm opacity-90"></div>
          <div class="w-1.5 h-8 bg-success rounded-sm opacity-90"></div>
          <div class="w-1.5 h-10 bg-success rounded-sm opacity-90"></div>
        </div>
      </div>
    </div>

    <!-- CARD 2: THE TRUTH (Interactive UX Choker) -->
    <div class="bg-bg-elevated border border-white/5 rounded-3xl p-7 sm:p-9 flex flex-col justify-between shadow-[0_12px_40px_rgba(0,0,0,0.4)] relative overflow-hidden group reveal reveal-delay-1">
      <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
      
      <div>
        <div class="text-[10px] font-mono text-accent uppercase tracking-widest mb-3">THE TRUTH</div>
        <h3 class="text-xl font-bold mb-3">Actual Speed Metrics</h3>
        <p class="text-text-secondary text-sm leading-relaxed mb-6">
          Calculates precise, real-time byte counters directly from local interfaces. Tells you immediately if data is flowing, VPN is choking, or the connection is flatlining—with zero telemetry tracking.
        </p>
      </div>

      <!-- Speed Value Visual & Drag Slider -->
      <div class="flex flex-col gap-4 mt-2">
        <div class="p-4 rounded-2xl bg-white/2 border border-white/5 flex items-center justify-between transition-colors relative overflow-hidden">
          <div class="flex flex-col">
            <span class="text-[9px] text-text-muted font-mono uppercase tracking-widest">REAL THROUGHPUT</span>
            <span class="text-[10px] font-mono text-success uppercase tracking-wide mt-0.5" id="slider-status">Fast / Streaming 4K</span>
          </div>
          <span class="font-mono text-xl sm:text-2xl font-bold tracking-tight tabular-nums transition-colors text-success" id="slider-speed-val">
            78.4 MB/s
          </span>
        </div>
        
        <!-- Drag Slider -->
        <div class="px-1.5">
          <div class="flex items-center justify-between text-[9px] font-mono text-text-muted uppercase mb-1.5">
            <span>Stuck / 0 KB/s</span>
            <span>Broadband Max</span>
          </div>
          <input 
            type="range" 
            min="0" 
            max="100" 
            value="80" 
            class="w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-accent" 
            id="speed-choke-slider"
          />
        </div>
      </div>
      
    </div>

  </div>
</section>

<script>
  const slider = document.getElementById('speed-choke-slider') as HTMLInputElement;
  const speedVal = document.getElementById('slider-speed-val');
  const statusLabel = document.getElementById('slider-status');

  function updateChoker() {
    if (!slider || !speedVal || !statusLabel) return;
    const val = parseFloat(slider.value);
    
    if (val === 0) {
      speedVal.textContent = '0.0 KB/s';
      speedVal.className = 'font-mono text-xl sm:text-2xl font-bold tracking-tight tabular-nums text-danger';
      statusLabel.textContent = 'Connection Dropped!';
      statusLabel.className = 'text-[10px] font-mono text-danger uppercase tracking-wider mt-0.5';
    } else if (val < 15) {
      const speed = (val * 12.5).toFixed(0);
      speedVal.textContent = `${speed} KB/s`;
      speedVal.className = 'font-mono text-xl sm:text-2xl font-bold tracking-tight tabular-nums text-danger';
      statusLabel.textContent = 'Dropbox Stuck / VPN choked';
      statusLabel.className = 'text-[10px] font-mono text-danger/80 uppercase tracking-wider mt-0.5';
    } else if (val < 45) {
      const speed = (0.1 + (val - 15) * 0.05).toFixed(2);
      speedVal.textContent = `${speed} MB/s`;
      speedVal.className = 'font-mono text-xl sm:text-2xl font-bold tracking-tight tabular-nums text-warning';
      statusLabel.textContent = 'Zoom Call Stuttering';
      statusLabel.className = 'text-[10px] font-mono text-warning uppercase tracking-wider mt-0.5';
    } else {
      const speed = (1.5 + (val - 45) * 1.7).toFixed(1);
      speedVal.textContent = `${speed} MB/s`;
      speedVal.className = 'font-mono text-xl sm:text-2xl font-bold tracking-tight tabular-nums text-success';
      statusLabel.textContent = 'Fast / Streaming 4K Active';
      statusLabel.className = 'text-[10px] font-mono text-success uppercase tracking-wider mt-0.5';
    }
  }

  if (slider) {
    slider.addEventListener('input', updateChoker);
    updateChoker();
  }
</script>

<style>
  /* Customizing standard slider background */
  input[type="range"]::-webkit-slider-runnable-track {
    background: rgba(255, 255, 255, 0.08);
    height: 4px;
    border-radius: 9999px;
  }
  input[type="range"]::-webkit-slider-thumb {
    margin-top: -6px;
    background: var(--color-accent);
    box-shadow: 0 0 10px var(--color-accent-glow);
    border-radius: 9999px;
    height: 16px;
    width: 16px;
    border: 2px solid white;
    appearance: none;
    -webkit-appearance: none;
  }
</style>
