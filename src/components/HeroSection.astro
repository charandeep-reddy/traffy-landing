---
import { DOWNLOAD_URL, REPO_URL } from '../constants';
---

<section class="min-h-screen flex flex-col items-center justify-center text-center px-6 relative overflow-hidden pt-28 pb-20 bg-black">
  
  <!-- Backdrops & Glowing Purple Spotlights -->
  <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[90vw] max-w-[1200px] h-[75vh] pointer-events-none"
       style="background: radial-gradient(ellipse at center, rgba(88,86,214,0.13) 0%, transparent 60%); font-display: swap;">
  </div>
  <div class="absolute inset-0 pointer-events-none"
       style="background-image: linear-gradient(rgba(255,255,255,0.006) 1px, transparent 1px),
                             linear-gradient(90deg, rgba(255,255,255,0.006) 1px, transparent 1px);
              background-size: 60px 60px;
              mask-image: radial-gradient(ellipse at center, black 25%, transparent 70%);
              -webkit-mask-image: radial-gradient(ellipse at center, black 25%, transparent 70%);">
  </div>

  <div class="max-w-[900px] mx-auto flex flex-col items-center relative z-10">
    
    <!-- Built for macOS Active Badge -->
    <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-accent text-[11px] font-semibold tracking-wide mb-8 reveal">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
      </span>
      Built for macOS Sequoia & Sonoma
    </div>

    <!-- Grand Headline -->
    <h1 class="font-display text-[clamp(44px,7.5vw,84px)] font-bold tracking-[-0.04em] leading-[1.05] mb-6 reveal reveal-delay-1">
      Your network speed.<br>
      <span class="text-gradient">Always visible.</span>
    </h1>

    <p class="text-text-secondary text-[clamp(15px,1.8vw,18px)] max-w-[480px] leading-relaxed mb-12 reveal reveal-delay-2">
      Real-time upload and download speeds in your macOS menu bar. 
      No heavy dashboards. Pure native Swift.
    </p>

    <!-- macOS Desktop Mockup Canvas Frame -->
    <div class="relative w-full max-w-[780px] aspect-[16/10] rounded-2xl p-[1px] overflow-hidden group shadow-[0_30px_80px_rgba(0,0,0,0.85)] border border-white/10 bg-[#09090b]/80 backdrop-blur-md reveal reveal-delay-3 mb-16 transition-all duration-500 hover:border-white/25">
      
      <!-- macOS Desktop Top Bar -->
      <div class="h-7 bg-black/60 backdrop-blur-md border-b border-white/5 px-4 flex items-center justify-between font-sans text-[11px] font-semibold tracking-tight text-[#f5f5f7]/95 select-none relative z-20">
        <!-- Left Menu Items -->
        <div class="flex items-center gap-4">
          <span class="text-white text-xs select-none"></span>
          <span class="font-bold">Finder</span>
          <span class="opacity-60 hover:opacity-100 transition-opacity cursor-default">File</span>
          <span class="opacity-60 hover:opacity-100 transition-opacity cursor-default">Edit</span>
          <span class="opacity-60 hover:opacity-100 transition-opacity cursor-default">View</span>
          <span class="opacity-60 hover:opacity-100 transition-opacity cursor-default">Go</span>
        </div>
        
        <!-- Right Menu (Traffy in its Native Habitat!) -->
        <div class="flex items-center gap-4">
          <!-- Traffy menu bar speed visual -->
          <div class="flex items-center gap-3 px-2 py-0.5 rounded bg-white/5 border border-white/5 font-mono text-[11px] font-bold tracking-wide tabular-nums text-text select-none">
            <span class="text-success flex items-center gap-1">↓ <span class="text-text">24.1</span> <span class="text-[8px] text-text-muted font-sans font-normal lowercase tracking-tight">MB/s</span></span>
            <span class="text-accent flex items-center gap-1">↑ <span class="text-text">4.8</span> <span class="text-[8px] text-text-muted font-sans font-normal lowercase tracking-tight">MB/s</span></span>
          </div>
          
          <!-- System Status icons -->
          <span class="opacity-70 flex items-center">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z"/>
            </svg>
          </span>
          <span class="opacity-80">9:41 AM</span>
        </div>
      </div>
      
      <!-- Blurred Abstract macOS Wallpaper Canvas -->
      <div class="absolute inset-x-0 bottom-0 top-7 bg-gradient-to-tr from-[#100f2e] via-[#050508] to-[#2a0738] overflow-hidden flex items-center justify-center z-10">
        <!-- Background light spotlight nodes -->
        <div class="absolute w-[280px] h-[280px] rounded-full bg-accent/20 blur-[90px] animate-pulse-dot pointer-events-none"></div>
        <div class="absolute w-[180px] h-[180px] rounded-full bg-[#af52de]/15 blur-[70px] -translate-y-8 pointer-events-none"></div>
        
        <!-- Giant Floating App Logo Card -->
        <div class="flex flex-col items-center gap-4 z-10 transition-transform duration-700 ease-out group-hover:scale-105 pointer-events-none">
          <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-[22px] sm:rounded-[26px] bg-gradient-to-tr from-[#5856D6] to-[#AF52DE] flex items-center justify-center shadow-[0_16px_45px_rgba(88,86,214,0.45)] border border-white/10 relative overflow-hidden">
            <svg viewBox="0 0 100 100" class="w-10 h-10 sm:w-12 sm:h-12 relative z-10" fill="none">
              <path d="M50 22 L50 62 M38 34 L50 22 L62 34" stroke="white" stroke-width="7.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M34 60 L50 78 L66 60" stroke="white" stroke-width="7.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.75"/>
            </svg>
          </div>
          <span class="font-display text-xl sm:text-2xl font-extrabold tracking-tight text-white drop-shadow-md">Traffy</span>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-wrap gap-4 justify-center reveal reveal-delay-3">
      <a href={DOWNLOAD_URL}
         class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent text-white rounded-full font-semibold text-xs no-underline
                transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_8px_30px_rgba(88,86,214,0.35)] hover:bg-accent/90 shadow-[0_4px_16px_rgba(88,86,214,0.2)]">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download for macOS
      </a>
      <a href={REPO_URL}
         class="inline-flex items-center gap-2 px-8 py-3.5 bg-bg-card text-text rounded-full font-semibold text-xs no-underline
                border border-white/5 transition-all duration-300 hover:bg-white/5 hover:border-white/10 shadow-[0_4px_16px_rgba(0,0,0,0.2)]">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View Code
      </a>
    </div>
  </div>
</section>
