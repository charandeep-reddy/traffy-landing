---
import MenuBarMockup from './MenuBarMockup.astro';
---

<section class="text-center px-6 py-[100px] pb-20 reveal"
         style="background: radial-gradient(ellipse at center, rgba(0,122,255,0.04) 0%, transparent 60%);">
  <div class="w-[120px] h-[120px] mx-auto mb-8 rounded-[28px] flex items-center justify-center glow-accent-lg"
       style="background: linear-gradient(135deg, #007AFF, #00d4ff);">
    <svg viewBox="0 0 100 100" class="w-14 h-14" fill="none">
      <path d="M50 22 L50 62 M38 34 L50 22 L62 34" stroke="white" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M34 60 L50 78 L66 60" stroke="white" stroke-width="7" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
    </svg>
  </div>

  <h2 class="font-display text-[clamp(40px,10vw,80px)] font-extrabold tracking-[-0.06em] text-gradient mb-6">
    Traffy
  </h2>
  <MenuBarMockup />
  <p class="text-[18px] text-text-secondary max-w-[500px] mx-auto mt-12">
    Live upload and download speeds. Always visible. Always real.
  </p>

</section>
