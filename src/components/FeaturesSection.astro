---
// FeaturesSection.astro
---

<section class="max-w-[1000px] mx-auto px-6 py-24 sm:py-32" id="features">
  
  <!-- Header -->
  <div class="text-center mb-16 sm:mb-20 reveal">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-accent/10 border border-accent/15 text-accent text-[10px] font-bold uppercase tracking-wider mb-4">
      Features
    </div>
    <h2 class="font-display text-[clamp(28px,3.8vw,48px)] font-bold tracking-[-0.03em] mb-4">
      Pure Native Modules.
    </h2>
    <p class="text-text-secondary text-[15px] sm:text-base max-w-[480px] mx-auto">
      Six custom system modules built with zero telemetry and zero background waste.
    </p>
  </div>

  <!-- Bento Grid: Balanced 2-1, 1-2, 2-1 layout -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    
    <!-- ================= ROW 1 (2 - 1) ================= -->
    
    <!-- CARD 1: Split & Combined Views (Span 2) -->
    <div class="md:col-span-2 group bg-bg-elevated border border-white/5 rounded-3xl p-6 sm:p-8 flex flex-col justify-between hover:border-white/10 hover:bg-[#0c0c11] transition-all duration-300 relative overflow-hidden reveal">
      <div class="absolute -right-10 -bottom-10 w-44 h-44 rounded-full bg-accent/5 blur-3xl pointer-events-none group-hover:bg-accent/8 transition-colors"></div>
      
      <div>
        <div class="w-10 h-10 rounded-xl bg-accent-dim flex items-center justify-center mb-6 text-accent group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold mb-2">Split or Combined Output</h3>
        <p class="text-text-secondary text-sm leading-relaxed max-w-[420px]">
          Show both download and upload speeds simultaneously side-by-side, or choose Combined mode to automatically show only the single dominant active direction.
        </p>
      </div>

      <!-- Mock Visual -->
      <div class="mt-8 flex gap-4 p-1.5 rounded-2xl bg-white/2 border border-white/5 w-fit">
        <div class="px-3.5 py-2 rounded-xl bg-bg border border-white/5 flex flex-col gap-1">
          <span class="text-[8px] text-text-muted font-mono tracking-wider">SPLIT</span>
          <span class="font-mono text-xs font-semibold flex gap-2">
            <span class="text-success">↓ 24.1</span>
            <span class="text-accent">↑ 4.8</span>
          </span>
        </div>
        <div class="px-3.5 py-2 rounded-xl bg-bg/40 border border-transparent flex flex-col gap-1 opacity-60">
          <span class="text-[8px] text-text-muted font-mono tracking-wider">COMBINED</span>
          <span class="font-mono text-xs font-semibold text-success">↓ 24.1</span>
        </div>
      </div>
    </div>

    <!-- CARD 2: Zero Telemetry (Span 1) -->
    <div class="group bg-bg-elevated border border-white/5 rounded-3xl p-6 sm:p-8 flex flex-col justify-between hover:border-white/10 hover:bg-[#0c0c11] transition-all duration-300 relative overflow-hidden reveal reveal-delay-1">
      <div class="absolute -right-10 -bottom-10 w-32 h-32 rounded-full bg-success/5 blur-3xl pointer-events-none"></div>
      
      <div>
        <div class="w-10 h-10 rounded-xl bg-success/10 border border-success/10 flex items-center justify-center mb-6 text-success group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold mb-2">Zero Telemetry</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Your network statistics never leave your device. Traffy does not make network calls, has no server trackers, and collects absolutely zero telemetry data.
        </p>
      </div>

      <div class="mt-8 text-xs font-mono text-success bg-success/5 border border-success/10 px-3 py-1.5 rounded-lg w-fit">
        100% Private
      </div>
    </div>

    <!-- ================= ROW 2 (1 - 2) ================= -->

    <!-- CARD 3: Bytes or Bits (Span 1) -->
    <div class="group bg-bg-elevated border border-white/5 rounded-3xl p-6 sm:p-8 flex flex-col justify-between hover:border-white/10 hover:bg-[#0c0c11] transition-all duration-300 relative overflow-hidden reveal">
      <div>
        <div class="w-10 h-10 rounded-xl bg-accent-dim flex items-center justify-center mb-6 text-accent group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold mb-2">Bytes or Bits</h3>
        <p class="text-text-secondary text-sm leading-relaxed font-normal">
          Toggle easily between standard bytes (`B/s`, `KB/s`, `MB/s`) or network engineer bits (`b/s`, `Kbps`, `Mbps`) modes depending on your specific requirements.
        </p>
      </div>

      <div class="mt-8 flex gap-2 font-mono text-[11px] font-semibold text-text-secondary">
        <span class="px-2 py-1 bg-white/5 border border-white/5 rounded-md">MB/s</span>
        <span class="px-2 py-1 bg-white/5 border border-white/5 rounded-md">Mbps</span>
      </div>
    </div>

    <!-- CARD 4: Your Interval (Span 2) -->
    <div class="md:col-span-2 group bg-bg-elevated border border-white/5 rounded-3xl p-6 sm:p-8 flex flex-col justify-between hover:border-white/10 hover:bg-[#0c0c11] transition-all duration-300 relative overflow-hidden reveal reveal-delay-1">
      <div class="absolute -right-10 -bottom-10 w-44 h-44 rounded-full bg-accent/5 blur-3xl pointer-events-none"></div>

      <div>
        <div class="w-10 h-10 rounded-xl bg-accent-dim flex items-center justify-center mb-6 text-accent group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold mb-2">Custom Update Rates</h3>
        <p class="text-text-secondary text-sm leading-relaxed max-w-[420px]">
          Configure how frequently Traffy queries local interface counters. Choose an update interval of **1 second**, **2 seconds**, or **3 seconds** to preserve CPU resources.
        </p>
      </div>

      <!-- Mock Visual -->
      <div class="mt-8 flex items-center gap-6">
        <div class="flex gap-2 p-1 bg-white/3 border border-white/5 rounded-xl w-fit">
          <span class="px-3 py-1 rounded-lg text-xs font-semibold bg-accent text-white shadow-sm">1s</span>
          <span class="px-3 py-1 rounded-lg text-xs font-semibold text-text-secondary">2s</span>
          <span class="px-3 py-1 rounded-lg text-xs font-semibold text-text-secondary">3s</span>
        </div>
        <span class="text-[11px] font-mono text-text-muted">Preserves CPU & Battery</span>
      </div>
    </div>

    <!-- ================= ROW 3 (2 - 1) ================= -->

    <!-- CARD 5: Featherweight Metrics (Span 2) -->
    <div class="md:col-span-2 group bg-bg-elevated border border-white/5 rounded-3xl p-6 sm:p-8 flex flex-col justify-between hover:border-white/10 hover:bg-[#0c0c11] transition-all duration-300 relative overflow-hidden reveal">
      <div class="absolute -right-10 -bottom-10 w-44 h-44 rounded-full bg-accent/5 blur-3xl pointer-events-none"></div>

      <div>
        <div class="w-10 h-10 rounded-xl bg-accent-dim flex items-center justify-center mb-6 text-accent group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold mb-2">Featherweight Footprint</h3>
        <p class="text-text-secondary text-sm leading-relaxed max-w-[440px]">
          No heavy Electron browser wrapper or Node.js runtime loaded in the background. Compact compiler outputs under pure Swift 6 architecture means minimal storage footprint.
        </p>
      </div>

      <!-- Symmetrical visual metrics -->
      <div class="mt-8 flex gap-8 text-[10px] font-mono text-text-secondary uppercase">
        <div class="flex flex-col">
          <span class="text-text-muted">MEMORY USAGE</span>
          <span class="text-text font-semibold text-xs mt-0.5">&lt; 15 MB RAM</span>
        </div>
        <div class="flex flex-col">
          <span class="text-text-muted">DISK STORAGE</span>
          <span class="text-text font-semibold text-xs mt-0.5">&lt; 2.0 MB</span>
        </div>
        <div class="flex flex-col">
          <span class="text-text-muted">CPU FOOTPRINT</span>
          <span class="text-success font-semibold text-xs mt-0.5">~0.0% IDLE</span>
        </div>
      </div>
    </div>

    <!-- CARD 6: Launch at Login (Span 1) -->
    <div class="group bg-bg-elevated border border-white/5 rounded-3xl p-6 sm:p-8 flex flex-col justify-between hover:border-white/10 hover:bg-[#0c0c11] transition-all duration-300 relative overflow-hidden reveal reveal-delay-1">
      <div class="absolute -right-10 -bottom-10 w-32 h-32 rounded-full bg-accent/5 blur-3xl pointer-events-none"></div>

      <div>
        <div class="w-10 h-10 rounded-xl bg-accent-dim flex items-center justify-center mb-6 text-accent group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold mb-2">Launch at Login</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Starts automatically at boot, living quietly inside your system menu bar. Powered by native OS `SMAppService` APIs.
        </p>
      </div>

      <!-- Mock Switch -->
      <div class="mt-8 flex items-center gap-2">
        <div class="w-3.5 h-3.5 rounded-full bg-success/20 flex items-center justify-center border border-success/30">
          <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
        </div>
        <span class="text-[11px] font-semibold text-text-secondary font-mono">Status: Ready</span>
      </div>
    </div>

  </div>
</section>
