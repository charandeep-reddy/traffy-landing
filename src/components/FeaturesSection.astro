---
const features = [
  { icon: 'split', title: 'Split or Combined', desc: "See both upload and download speeds, or just the direction that's active. Your call." },
  { icon: 'scale', title: 'Bytes or Bits', desc: 'B/s, KB/s, MB/s or b/s, Kbps, Mbps. Whichever unit makes sense for you.' },
  { icon: 'clock', title: 'Your Interval', desc: 'Refresh every 1, 2, or 3 seconds. However you like to see your network breathe.' },
  { icon: 'power', title: 'Launch at Login', desc: "Starts when you start. Lives in the menu bar. Never in the dock." },
  { icon: 'shield', title: 'Zero Bloat', desc: 'Pure Swift. Reads local system counters. No network calls. No telemetry. No tracking.' },
  { icon: 'device', title: 'Native Feel', desc: 'macOS 13+. Apple Silicon and Intel. Feels like it grew up in your menu bar.' },
];

// Helper to determine bento grid column span classes for '2-1, 1-2, 2-1' on medium screens and up
const getColSpanClass = (index: number) => {
  if (index === 0 || index === 3 || index === 4) {
    return 'md:col-span-2';
  }
  return 'md:col-span-1';
};
---

<section class="max-w-[1020px] mx-auto px-6 py-20 sm:py-28" id="features">
  <div class="text-center mb-12 sm:mb-16 reveal">
    <h2 class="font-display text-[clamp(26px,4vw,40px)] font-bold tracking-tight mb-3">
      Everything you need.<br class="sm:hidden">
      <span class="text-text-secondary font-serif italic">Nothing you don't.</span>
    </h2>
    <p class="text-text-secondary text-xs sm:text-[14px] font-medium uppercase tracking-wider">Six features. Zero bloat.</p>
  </div>

  <!-- Bento Grid Container -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    {features.map((f, i) => (
      <div class:list={[
        "group bg-bg-card border border-border rounded-2xl p-6 sm:p-8 reveal transition-all duration-300 hover:shadow-md hover:border-text/10",
        getColSpanClass(i)
      ]}>
        <div class="w-10 h-10 rounded-xl bg-accent-dim flex items-center justify-center mb-5 text-accent transition-transform duration-300 group-hover:scale-105">
          {f.icon === 'split' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>}
          {f.icon === 'scale' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>}
          {f.icon === 'clock' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>}
          {f.icon === 'power' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
          {f.icon === 'shield' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>}
          {f.icon === 'device' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>}
        </div>
        
        <div class="max-w-[480px]">
          <h3 class="text-md font-bold mb-2 text-text">{f.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed font-medium">{f.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>
