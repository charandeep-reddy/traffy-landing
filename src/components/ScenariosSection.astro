<section class="max-w-[780px] mx-auto px-6 py-20 sm:py-28">
  <div class="text-center mb-12 sm:mb-16 reveal">
    <h2 class="font-display text-[clamp(26px,3.5vw,40px)] font-bold tracking-tight mb-3">Why it matters</h2>
    <p class="text-text-secondary text-[15px] sm:text-[16px] font-medium">Real problems your menu bar won't ever show you.</p>
  </div>

  <div class="space-y-4">
    <!-- Alert 1: Upload Stuck -->
    <div class="bg-bg-card border border-border border-l-4 border-l-danger rounded-xl p-6 flex gap-4 sm:gap-5 reveal transition-all duration-300 hover:shadow-sm">
      <div class="shrink-0 mt-0.5 text-danger">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>
      <div>
        <h3 class="text-[15px] font-bold text-text mb-1">
          Your upload is stuck at <code class="font-mono text-xs text-danger bg-danger/5 border border-danger/10 px-1.5 py-0.5 rounded font-bold">0 KB/s</code>
        </h3>
        <p class="text-text-secondary text-sm leading-relaxed font-medium">
          Dropbox isn't syncing or your VPN is choking. The menu bar signal bars say full. Traffy reveals the absolute truth instantly.
        </p>
      </div>
    </div>

    <!-- Alert 2: Zoom Call lag -->
    <div class="bg-bg-card border border-border border-l-4 border-l-accent rounded-xl p-6 flex gap-4 sm:gap-5 reveal reveal-delay-1 transition-all duration-300 hover:shadow-sm">
      <div class="shrink-0 mt-0.5 text-accent">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </div>
      <div>
        <h3 class="text-[15px] font-bold text-text mb-1">
          You are on a video call and the video stutters.
        </h3>
        <p class="text-text-secondary text-sm leading-relaxed font-medium">
          The Wi-Fi bars look fully healthy, but Traffy shows your upload has dropped to <code class="font-mono text-xs text-accent bg-accent/5 border border-accent/10 px-1.5 py-0.5 rounded font-bold">0.2 Mbps</code>. Now you know exactly why it's lagging.
        </p>
      </div>
    </div>

    <!-- Alert 3: Download drop -->
    <div class="bg-bg-card border border-border border-l-4 border-l-danger rounded-xl p-6 flex gap-4 sm:gap-5 reveal reveal-delay-2 transition-all duration-300 hover:shadow-sm">
      <div class="shrink-0 mt-0.5 text-danger">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
      <div>
        <h3 class="text-[15px] font-bold text-text mb-1">
          Your download drops to zero mid-stream.
        </h3>
        <p class="text-text-secondary text-sm leading-relaxed font-medium">
          Your 4K video buffer is emptying. Traffy catches the failure in real-time, letting you verify that it's the provider, not your laptop.
        </p>
      </div>
    </div>
  </div>
</section>
