---
import '../styles/global.css';
import { DOWNLOAD_URL, REPO_URL, LICENSE_URL } from '../constants';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Traffy — Network speed in your menu bar</title>
  <meta name="description" content="Real-time upload and download speeds in your macOS menu bar. Lightweight, native Swift. Free &amp; open source.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://traffy.psydevx.app">
  <meta property="og:title" content="Traffy — Network speed in your menu bar">
  <meta property="og:description" content="Real-time upload and download speeds in your macOS menu bar. Lightweight, native Swift. Free &amp; open source.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://traffy.psydevx.app">
  <meta property="og:site_name" content="Traffy">
  <meta property="og:image" content="https://traffy.psydevx.app/favicon.svg">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Traffy — Network speed in your menu bar">
  <meta name="twitter:description" content="Real-time upload and download speeds in your macOS menu bar. Lightweight, native Swift. Free &amp; open source.">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Floating Pill-header Nav -->
  <header class="fixed top-4 left-0 right-0 z-50 flex justify-center px-4">
    <nav class="glass max-w-[580px] w-full h-11 px-4 rounded-full flex items-center justify-between shadow-[0_4px_16px_rgba(0,0,0,0.04)] border border-border">
      <a href="#" class="flex items-center gap-2 text-xs font-bold text-text no-underline">
        <svg viewBox="0 0 100 100" class="w-4 h-4" fill="none">
          <defs>
            <linearGradient id="navIcon" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#007AFF"/>
              <stop offset="100%" stop-color="#5856d6"/>
            </linearGradient>
          </defs>
          <rect x="5" y="5" width="90" height="90" rx="22" fill="url(#navIcon)"/>
          <path d="M50 22 L50 62 M38 34 L50 22 L62 34" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M34 60 L50 78 L66 60" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" opacity="0.75"/>
        </svg>
        <span class="tracking-tight">Traffy</span>
      </a>
      <div class="flex items-center gap-4">
        <a href="#problem" class="text-text-secondary text-[11px] font-medium no-underline hover:text-text transition-colors">Problem</a>
        <a href="#features" class="text-text-secondary text-[11px] font-medium no-underline hover:text-text transition-colors">Features</a>
        <a href="#tech" class="text-text-secondary text-[11px] font-medium no-underline hover:text-text transition-colors">Specs</a>
        <a href={DOWNLOAD_URL}
           class="bg-accent text-white px-3 py-1 rounded-full text-[10px] font-bold no-underline hover:bg-accent/90 transition-colors shadow-sm">
          Download
        </a>
      </div>
    </nav>
  </header>

  <slot />

  <!-- Footer -->
  <footer class="border-t border-border py-12 px-6 bg-bg-elevated/40">
    <div class="max-w-[640px] mx-auto flex flex-col items-center gap-4 text-center">
      <div class="flex items-center gap-5 text-xs text-text-muted">
        <a href={REPO_URL} class="no-underline hover:text-text transition-colors">GitHub</a>
        <a href={LICENSE_URL} class="no-underline hover:text-text transition-colors">MIT License</a>
        <a href="https://psydevx.app" class="no-underline hover:text-accent transition-colors font-medium">Made by psydevx</a>
      </div>
      <p class="text-[11px] text-text-muted">&copy; 2026 Traffy. Handcrafted for macOS.</p>
    </div>
  </footer>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Traffy",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "macOS",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })}></script>

  <!-- Scroll Reveal Script -->
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
